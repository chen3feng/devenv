# Shared by both bash and zsh

if [[ -z "$_THIS_DIR" ]]; then
    echo "Error: don't source this file directly, source '_bashrc' or '_zshrc'"
    return
fi

# Settings (PATH, exports) first, the rest sorted alphabetically.
source "$_THIS_DIR"/shell/settings

source "$_THIS_DIR"/shell/alias
source "$_THIS_DIR"/shell/alt_screen
source "$_THIS_DIR"/shell/find_sources
source "$_THIS_DIR"/shell/git
source "$_THIS_DIR"/shell/locale
source "$_THIS_DIR"/shell/macos
source "$_THIS_DIR"/shell/path_manager
source "$_THIS_DIR"/shell/proxy
source "$_THIS_DIR"/shell/trash_rm
source "$_THIS_DIR"/shell/vscode
