#!/bin/bash
# Author: CHEN Feng <chen3feng@gmail.com>
# Date: 2012-01-18
# Description: a rm function with trash support

# ===========================================================================
# How to use:
# ---------------------------------------------------------------------------
# 1. Download this script
# 2. Add the following line into your ~/.bashrc (or ~/.zshrc on macOS):
# ------------------------------
#    source /path/to/trash_rm
# ------------------------------
# 3. Relogin or run `source ~/.bashrc`
# 4. Your rm command is now replaced (call original rm via /bin/rm or -D flag)
# 5. Enjoy it!
#
# macOS: files are moved to Finder's Trash (via osascript).
# Linux: files are moved to ~/.local/trash, organized by date.
#
# ===========================================================================
# How to view removed files (Linux):
# ---------------------------------------------------------------------------
#   cd ~/.local/trash
#   ls lastday/
#
# All removed files are organized by date and time under subdirectories.
#
# ===========================================================================
# How to restore removed files (Linux):
# ---------------------------------------------------------------------------
# Use mv or cp to restore:
#   mv ~/.local/trash/lastday/<timestamp>_<filename> /desired/path/
#
# ===========================================================================
# How to empty the trash:
# ---------------------------------------------------------------------------
#   trash_clean
#
# ===========================================================================
# How to remove a file permanently (skip trash):
# ---------------------------------------------------------------------------
#   rm -D <file>            # -D means directly, bypasses trash
#   /bin/rm <file>          # or call the original rm directly
#
# To remove files already in trash, use /bin/rm directly.

# The path of trash directory
TRASH_DIR="$HOME/.local/trash"

if [[ "$OSTYPE" == "darwin"* ]]; then
    realpath() {
        [[ $1 = /* ]] && echo "$1" || echo "$PWD/${1#./}"
    }
fi

# bool _file_in_dir(string file, string dir)
_file_in_dir() {
    local file dir file_dir
    file="$(realpath "$1")"
    dir="$2"
    file_dir="$file"
    while :; do
        if [[ "$file_dir" == "$dir" ]]; then
            return 0
        fi
        file_dir=$(dirname "$file_dir")
        if [[ "$file_dir" == "/" ]]; then
            return 1
        fi
    done
}

_move_to_trash() {
    local verbose="$1"
    local arg="$2"
    local osas

    # Move it to the ~/.Trash dir under macOS
    if [[ "$(uname)" == Darwin ]]; then
        osas="tell application \"Finder\" to delete POSIX file \"${PWD}/${arg}\""
        if [[ -n "$verbose" ]]; then
            osascript -e "$osas"
        else
            osascript -e "$osas" >/dev/null
        fi
        return
    fi

    if [[ ! -d "$TRASH_DIR" ]]; then
        mkdir -p "$TRASH_DIR"
        echo "Trash dir $TRASH_DIR created."
    fi

    local timestamp date_dir target_name
    # macOS date doesn't support %N, use $RANDOM instead
    if [[ "$(uname)" == Darwin ]]; then
        timestamp="$(date +%Y%m%d.%H%M%S).$(printf "%05d" $RANDOM)"
    else
        timestamp="$(date +%Y%m%d.%H%M%S.%N)"
    fi
    # Put file into date-named subdirectory
    date_dir="$TRASH_DIR/${timestamp:0:8}"
    if [[ ! -e "$date_dir" ]]; then
        mkdir -p "$date_dir"
    fi
    # Symlink for quick access to today's trash
    /bin/rm -f "$TRASH_DIR/lastday"
    ln -sf "$date_dir" "$TRASH_DIR/lastday"
    target_name="$date_dir/${timestamp}  $(basename "$arg")"
    if [[ -n "$verbose" ]]; then
        echo "move $arg to $target_name"
    fi
    mv "$arg" "$target_name"
}

# This function replaces the system rm command.
rm() {
    local direct force interactive recursive verbose
    local trash_dir="$TRASH_DIR"

    if [[ "$(getopt 2>/dev/null)" == ' --' ]]; then
        # macOS getopt doesn't support long options
        if ! rm_args=$(getopt firDRv "$@"); then
            return 1
        fi
    else
        if ! rm_args=$(getopt -o firDRv -n rm --long direct,force,help,interactive,recursive,verbose,version -- "$@"); then
            return 1
        fi
    fi
    eval set -- "$rm_args"
    while [[ -n "$1" ]]; do
        case "$1" in
            -D|--direct)
                direct='-D'
                shift ;;
            -f|--force)
                force="-f"
                shift ;;
            -i|--interactive)
                interactive="-i"
                shift ;;
            -r|-R|--recursive)
                recursive="-r"
                shift ;;
            -v|--verbose)
                verbose="-v"
                shift ;;
            --help)
                /bin/rm "$1"
                printf '\nAdditional options:\n  -D, --direct          remove directly, don'"'"'t use trash\n'
                return ;;
            --version)
                /bin/rm "$1"
                return ;;
            --)
                shift
                break ;;
            *)
                echo "unknown option $1" >&2
                return 1 ;;
        esac
    done

    local arg confirm error

    if [[ -n "$direct" ]]; then
        /bin/rm $force $recursive $verbose $interactive "$@"
        return $?
    fi

    if [[ $# -eq 0 ]]; then
        if [[ -z "$force" ]]; then
            /bin/rm
        fi
        return
    fi

    error=0

    for arg in "$@"; do
        if _file_in_dir "$arg" "$trash_dir"; then
            /bin/rm $force $recursive $verbose $interactive "$arg"
            continue
        fi

        if ! stat "$arg" &>/dev/null; then
            if [[ -z "$force" ]]; then
                echo "rm: cannot remove '$arg': No such file or directory"
                error=1
            fi
            continue
        fi

        if [[ -d "$arg" && ! -L "$arg" && -z "$recursive" ]]; then
            echo "rm: cannot remove '$arg': Is a directory"
            error=1
            continue
        fi

        if [[ -n "$interactive" ]]; then
            local file_type
            if [[ -d "$arg" ]]; then
                file_type="directory"
            elif [[ -L "$arg" ]]; then
                file_type="symbolic link"
            else
                file_type="file"
            fi
            printf "rm: remove %s '%s'? " "$file_type" "$arg"
            read -r confirm
            if [[ "$confirm" != "y" ]]; then
                continue
            fi
        fi

        if [[ -L "$arg" ]]; then
            # Symbolic links are removed directly (trash is meaningless).
            if [[ -n "$verbose" ]]; then
                echo "rm symbolic link $arg"
            fi
            /bin/rm "$arg"
        else
            _move_to_trash "$verbose" "$arg"
        fi
    done

    return $error
}


trash_clean() {
    local item
    for item in "$TRASH_DIR"/*; do
        /bin/rm -fr "$item"
    done
}
