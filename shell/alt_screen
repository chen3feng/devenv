#!/bin/bash
#
# Toggle or control the terminal alternative screen buffer.
#
# Usage:
#   alt-screen         # toggle (enter if not in, leave if in)
#   alt-screen enter   # enter the alternative screen
#   alt-screen leave   # leave the alternative screen

IN_ALT_SCREEN=${IN_ALT_SCREEN:-0}
export IN_ALT_SCREEN

enter-alt-screen() {
    printf '\e[?1049h'
    IN_ALT_SCREEN=1
}

leave-alt-screen() {
    printf '\e[?1049l'
    IN_ALT_SCREEN=0
}

alt-screen() {
    if [[ "$1" == "enter" ]]; then
        enter-alt-screen
    elif [[ "$1" == "leave" ]]; then
        leave-alt-screen
    elif [[ "$IN_ALT_SCREEN" == "1" ]]; then
        leave-alt-screen
    else
        enter-alt-screen
    fi
}
