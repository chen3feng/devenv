# MacOS specific helpers (quarantine, code signing, sleep)

if [ "$(uname)" = "Darwin" ]; then
    # Recursively strip the quarantine attribute
    unquarantine() {
        if [ "$#" -eq "0" ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
            echo "Unquarantine files (recurses into directories)."
            echo "Usage:"
            echo "  unquarantine [-h|--help]"
            echo "  unquarantine files... dirs..."
            return 1
        fi
        xattr -rd com.apple.quarantine "$@"
    }

    # Sign and unquarantine an app so MacOS allows running it
    allowapp() {
        if [[ "$#" -eq 0 ]]; then
            echo "Usage: allowapp <path/to/app>"
            return 1
        fi
        codesign --sign - --force --deep "$@" && unquarantine "$@"
    }

    disablesleep() {
        sudo pmset -b disablesleep 1
    }

    restoresleep() {
        sudo pmset -b disablesleep 0
    }
fi
